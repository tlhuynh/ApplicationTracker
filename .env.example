# Local SQL Server (Docker) — copy this file to .env and fill in your values.
# .env is gitignored and never committed.
#
# SA_PASSWORD requirements (SQL Server enforced):
#   - 8+ characters
#   - Must include uppercase, lowercase, digit, and symbol

SA_PASSWORD=YourStrongPassword123!

# Optional: overrides the Docker Compose project name shown in Docker Desktop.
# Defaults to the repository folder name if not set.
COMPOSE_PROJECT_NAME=local_dev_db_sever_container